# Stage 1: Build Agent
FROM golang:1.26.1-alpine AS builder
WORKDIR /app
RUN apk add --no-cache git
COPY . .
RUN go build -o bin/chv-agent ./cmd/chv-agent

# Stage 2: Runtime
FROM alpine:latest

# Install hypervisor dependencies
RUN apk --no-cache add \
    ca-certificates \
    iproute2 \
    qemu-img \
    xorriso \
    wget \
    nftables

WORKDIR /app

# Download Cloud Hypervisor static binary
RUN wget https://github.com/cloud-hypervisor/cloud-hypervisor/releases/download/v51.1/cloud-hypervisor-static -O /usr/local/bin/cloud-hypervisor && \
    chmod +x /usr/local/bin/cloud-hypervisor

# Copy agent binary from builder
COPY --from=builder /app/bin/chv-agent .

# Create data directories
RUN mkdir -p /var/lib/chv /var/log/chv

EXPOSE 9090

ENV CHV_AGENT_ADDR=:9090
ENV CHV_DATA_ROOT=/var/lib/chv
ENV CHV_LOG_LEVEL=info

# Run as root for TAP device management
USER root

ENTRYPOINT ["./chv-agent"]

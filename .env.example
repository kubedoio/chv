# CHV Platform Environment Configuration
# Copy this file to .env and customize for your deployment

# =============================================================================
# Database Configuration
# =============================================================================
CHV_DB_HOST=postgres
CHV_DB_PORT=5432
CHV_DB_NAME=chv
CHV_DB_USER=chv
CHV_DB_PASSWORD=chv_secret_password
CHV_DATABASE_URL=postgres://chv:chv_secret_password@postgres:5432/chv?sslmode=disable

# =============================================================================
# API Configuration
# =============================================================================
CHV_API_BIND=:8080
CHV_API_BASE_URL=http://localhost:8082
CHV_API_JWT_SECRET=change_this_to_a_secure_random_string

# =============================================================================
# Agent Configuration
# =============================================================================
CHV_AGENT_GRPC_BIND=:9091
CHV_AGENT_HTTP_BIND=:10091
CHV_AGENT_DATA_DIR=/var/lib/chv
CHV_AGENT_LOG_LEVEL=info

# =============================================================================
# Bridge/Network Configuration
# =============================================================================
# Bridge name for VM networking
CHV_BRIDGE_NAME=chvbr0

# Uplink interface to attach to bridge (e.g., ens19, eth1)
# Leave empty to skip uplink attachment (Docker/testing environments)
CHV_BRIDGE_UPLINK=ens19

# Gateway IP for the bridge (VMs will use this as their default gateway)
CHV_BRIDGE_GATEWAY_IP=10.0.0.1

# VM network CIDR (must match gateway IP)
CHV_VM_NETWORK_CIDR=10.0.0.0/24

# =============================================================================
# VM Configuration
# =============================================================================
CHV_VM_DEFAULT_CPU=2
CHV_VM_DEFAULT_MEMORY_MB=2048
CHV_VM_DEFAULT_DISK_GB=20

# =============================================================================
# SSH Configuration (for cloud-init)
# =============================================================================
CHV_SSH_PUBLIC_KEY_PATH=/root/.ssh/chv_id_ed25519.pub

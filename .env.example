# CHV Environment Configuration
# Copy this file to .env and customize for your deployment
# Environment variables override settings in YAML config files

# =============================================================================
# Controller Configuration
# =============================================================================

# Server addresses
CHV_HTTP_ADDR=:8080
CHV_GRPC_ADDR=:9090

# Database connection (required)
# CHV_DATABASE_URL=postgres://user:password@localhost:5432/chv?sslmode=disable

# Logging
CHV_LOG_LEVEL=info
CHV_LOG_FORMAT=json

# Security (change in production!)
CHV_JWT_SECRET=your-secret-key-here
CHV_TOKEN_DURATION=24h

# CORS Origins (comma-separated)
# Include your WebUI server IP/domain here
CHV_CORS_ORIGINS=http://10.5.199.83,http://10.5.199.83:3000,http://localhost:3000

# =============================================================================
# Agent Configuration
# =============================================================================

# Node identification
CHV_NODE_ID=agent-01

# Server addresses
CHV_AGENT_LISTEN_ADDR=:8081
CHV_CONTROLLER_ADDR=localhost:9090

# Data directories
CHV_DATA_DIR=/var/lib/chv-agent
CHV_IMAGE_DIR=/var/lib/chv-agent/images
CHV_VOLUME_DIR=/var/lib/chv-agent/volumes

# Cloud Hypervisor
CHV_CLOUD_HYPERVISOR=/usr/bin/cloud-hypervisor

# Network
CHV_BRIDGE_NAME=br0

# Console
CHV_CONSOLE_PORT=8090

# Heartbeat
CHV_HEARTBEAT_INTERVAL=30s

# Stage 1: Build UI
FROM node:20-alpine AS ui-builder
WORKDIR /app/ui
COPY ui/package*.json ./
RUN rm -f package-lock.json && \
    npm install && \
    npm install @rollup/rollup-linux-arm64-musl
COPY ui/ .
RUN npm run build

# Stage 2: Build Controller
FROM golang:1.26.1-alpine AS controller-builder
WORKDIR /app
RUN apk add --no-cache git
COPY . .
RUN go build -o bin/chv-controller ./cmd/chv-controller

# Stage 3: Runtime
FROM alpine:latest
RUN apk --no-cache add ca-certificates

WORKDIR /app

# Copy binaries
COPY --from=controller-builder /app/bin/chv-controller .

# Copy UI build
COPY --from=ui-builder /app/ui/build ./ui/build

# Copy configuration and schema
COPY configs/ ./configs/

# Create data directories
RUN mkdir -p /var/lib/chv /var/log/chv

EXPOSE 8080

ENV CHV_HTTP_ADDR=:8080
ENV CHV_DATA_ROOT=/var/lib/chv
ENV CHV_LOG_LEVEL=info

ENTRYPOINT ["./chv-controller"]

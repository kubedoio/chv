FROM alpine:latest

RUN apk --no-cache add ca-certificates

WORKDIR /app

# Copy pre-built binary
COPY chv-controller .

# Copy UI build
COPY ui/build ./ui/build

# Create data directories
RUN mkdir -p /var/lib/chv /var/log/chv

EXPOSE 8080

ENV CHV_HTTP_ADDR=:8080
ENV CHV_DATA_ROOT=/var/lib/chv
ENV CHV_LOG_LEVEL=info

ENTRYPOINT ["./chv-controller"]
